@code {
    
    [Parameter]
    public User NewUser { get; set; } = new();

    [Parameter] public User InsertUser { get; set; } = new();
    
    
    // private FormModel formModel = new FormModel();
    

    private bool showUser = false;

    private User _user = new User();

    private async Task HandleValidSubmit()
    {
        showUser = true;
        
        // Console.WriteLine("IS THIS NULL? " + NewUser.Username);

        if (!string.IsNullOrWhiteSpace(NewUser.Username))
        {
            _user = await UserService.GetUserAsync(NewUser.Username);
            // Console.WriteLine("IS THIS NULL?" + _user.DisplayName);
            // _user = await UserService.GetUserAsync("testy");

            // await MessageService.SendMessageAsync(NewMsg);
            // _messages = await MessageService.GetAllMessagesAsync();
        }
        else
        {
            Logger.LogInformation("Client attempted to submit empty message");
        }
        
    }

    private async Task HandleInsertSubmit()
    {
        showUser = true;

        await UserService.SendUserAsync(InsertUser);
        _user = await UserService.GetUserAsync(InsertUser.Username);
    }
    

}

